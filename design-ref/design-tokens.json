{
  "$schema": "Design tokens for the Walkam (וולקאם) dark theme. Source of truth = Home screen design A. Values are literal CSS. Use these names 1:1 in your CSS variables / theme file.",
  "meta": {
    "name": "Walkam Dark",
    "version": "1.0.0",
    "direction": "rtl",
    "locale": "he-IL",
    "baseFontFamily": "Rubik",
    "platform": "mobile-first (390px), responsive up to desktop"
  },

  "color": {
    "brand": {
      "primary":        "#FF2E9A",
      "primaryHover":   "#FF49A9",
      "primaryActive":  "#E01F84",
      "primaryDisabled":"#7A2E5C",
      "onPrimary":      "#FFFFFF",

      "accent":         "#D8F500",
      "accentHover":    "#E4FF3A",
      "accentActive":   "#BCD600",
      "onAccent":       "#181A23"
    },

    "category": {
      "pink":  "#F8CCE4",
      "mint":  "#B7EAD4",
      "peach": "#FAD7BA",
      "rose":  "#F9CCE5",
      "lime":  "#D8F500",
      "onCategory": "#181A23"
    },

    "background": {
      "canvas":     "#0F1016",
      "app":        "#181A23",
      "surface":    "#252836",
      "surfaceAlt": "#2F3344",
      "navBar":     "#1B1D27",
      "overlay":    "rgba(10,11,16,0.6)",
      "scrim":      "rgba(0,0,0,0.45)"
    },

    "text": {
      "primary":    "#FFFFFF",
      "secondary":  "#9CA0AE",
      "tertiary":   "#7C808E",
      "onAccent":   "#181A23",
      "onCategory": "#181A23",
      "link":       "#FF2E9A",
      "disabled":   "#5A5E6B"
    },

    "border": {
      "subtle":   "rgba(255,255,255,0.06)",
      "default":  "#262936",
      "strong":   "#343847",
      "focus":    "#FF2E9A",
      "onLight":  "rgba(24,26,35,0.10)"
    },

    "state": {
      "success":   "#34D399",
      "successBg": "rgba(52,211,153,0.14)",
      "onSuccess": "#06281D",

      "error":     "#FF453A",
      "errorBg":   "rgba(255,69,58,0.14)",
      "onError":   "#FFFFFF",

      "warning":   "#FFB84D",
      "warningBg": "rgba(255,184,77,0.14)",
      "onWarning": "#2A1B00",

      "info":      "#4DA3FF",
      "infoBg":    "rgba(77,163,255,0.14)",
      "onInfo":    "#04203F",

      "notificationDot": "#FF3B30"
    }
  },

  "radius": {
    "xs":   "12px",
    "sm":   "16px",
    "md":   "20px",
    "lg":   "26px",
    "xl":   "28px",
    "pill": "999px",
    "circle": "50%",
    "device": "46px"
  },

  "shadow": {
    "none":  "none",
    "sm":    "0 2px 8px rgba(0,0,0,0.20)",
    "md":    "0 8px 24px rgba(0,0,0,0.30)",
    "lg":    "0 16px 40px rgba(0,0,0,0.40)",
    "float": "0 30px 70px rgba(0,0,0,0.50)",
    "sheet": "0 -12px 40px rgba(0,0,0,0.45)",
    "glowPrimary": "0 6px 20px rgba(255,46,154,0.35)",
    "glowAccent":  "0 6px 20px rgba(216,245,0,0.30)"
  },

  "spacing": {
    "0": "0px",
    "1": "2px",
    "2": "4px",
    "3": "8px",
    "4": "11px",
    "5": "14px",
    "6": "16px",
    "7": "20px",
    "8": "22px",
    "9": "24px",
    "10": "32px",
    "11": "40px",
    "12": "48px",
    "gutter": "22px",
    "sectionGap": "16px",
    "cardGap": "11px"
  },

  "typography": {
    "fontFamily": {
      "base": "'Rubik', system-ui, 'Segoe UI', Arial, sans-serif"
    },
    "weight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700,
      "extrabold": 800,
      "black": 900
    },
    "scale": {
      "display":  { "size": "30px", "lineHeight": "1.05", "weight": 800, "usage": "מספרים גדולים / hero ראשי" },
      "h1":       { "size": "25px", "lineHeight": "1.12", "weight": 800, "usage": "כותרת באנר" },
      "h2":       { "size": "19px", "lineHeight": "1.2",  "weight": 800, "usage": "Section Title (מה חדש)" },
      "title":    { "size": "17px", "lineHeight": "1.2",  "weight": 700, "usage": "כותרת בתוך כרטיס צבעוני" },
      "bodyLg":   { "size": "15px", "lineHeight": "1.35", "weight": 700, "usage": "כותרת סטטוס / כפתור" },
      "body":     { "size": "15px", "lineHeight": "1.45", "weight": 500, "usage": "טקסט גוף" },
      "cardTitle":{ "size": "13.5px","lineHeight": "1.25","weight": 700, "usage": "כותרת כרטיס פיד" },
      "label":    { "size": "13px", "lineHeight": "1.3",  "weight": 600, "usage": "תוויות / 'הכל'" },
      "caption":  { "size": "12.5px","lineHeight": "1.3", "weight": 500, "usage": "מטא-טקסט משני" },
      "micro":    { "size": "11px", "lineHeight": "1.2",  "weight": 700, "usage": "תוויות ניווט / תאריך בכרטיס" }
    }
  },

  "iconSize": {
    "sm": "16px",
    "md": "20px",
    "lg": "24px",
    "strokeWidth": "2"
  },

  "size": {
    "iconButton": "46px",
    "quickIcon": "40px",
    "feedBadge": "26px",
    "navIcon": "24px",
    "statusBarHeight": "52px",
    "bottomNavHeight": "84px",
    "homeIndicator": { "width": "130px", "height": "5px" },
    "hitTargetMin": "44px"
  },

  "motion": {
    "fast": "120ms",
    "base": "200ms",
    "slow": "320ms",
    "easing": "cubic-bezier(0.22, 1, 0.36, 1)"
  },

  "zIndex": {
    "base": 0,
    "header": 10,
    "bottomNav": 20,
    "sheet": 50,
    "modal": 60,
    "toast": 70
  }
}
